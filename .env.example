# Auth : par Personal Access Token (PAT) Azure DevOps, saisi dans l'UI de
# connexion — aucun secret Azure AD à configurer ici.

# Database
DATABASE_URL=postgresql://moirai:moirai@localhost:5432/moirai

# Redis
REDIS_URL=redis://localhost:6379

# Session
# 32 caractères minimum — générer avec : openssl rand -hex 32
SESSION_SECRET=dev-secret-local-0123456789abcdef0123456789abcdef

# App
PORT=3000
FRONTEND_URL=http://localhost:5173
