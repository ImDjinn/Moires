# Copier en .env.production sur le serveur et remplir. NE PAS committer .env.production.
# Les hôtes DB/Redis sont les NOMS DE SERVICE compose (postgres, redis), pas localhost.

# Azure AD / MSAL
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_REDIRECT_URI=https://themoirai.net/auth/callback

# Azure DevOps
ADO_ORG_URL=https://dev.azure.com/your-org

# Base de données
POSTGRES_USER=moirai
POSTGRES_PASSWORD=CHANGER_mot_de_passe_fort
POSTGRES_DB=moirai
DATABASE_URL=postgresql://moirai:CHANGER_mot_de_passe_fort@postgres:5432/moirai

# Redis
REDIS_URL=redis://redis:6379

# Session — générer avec : openssl rand -hex 32
SESSION_SECRET=CHANGER_openssl_rand_hex_32

# App
PORT=3000
FRONTEND_URL=https://themoirai.net
