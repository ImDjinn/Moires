generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  azureAdId   String   @unique @map("azure_ad_id")
  displayName String   @map("display_name")
  email       String
  defaultAdoOrg String? @map("default_ado_org")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  operationsLog OperationsLog[]
  sessions      PlanningSession[]

  @@map("users")
}

model PlanningSession {
  id              String   @id @default(uuid())
  adoOrg          String   @map("ado_org")
  adoProjectId    String   @map("ado_project_id")
  adoIterationIds String[] @map("ado_iteration_ids")
  areaPaths       String[] @map("area_paths")
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  creator       User            @relation(fields: [createdBy], references: [id])
  operationsLog OperationsLog[]
  ticketsCache  TicketsCache[]

  @@map("planning_sessions")
}

/// Jalon de release, persisté par projet ADO (et non par session) — partagé
/// entre toutes les sessions du projet et conservé après leur expiration.
model Milestone {
  id           String @id @default(uuid())
  adoProjectId String @map("ado_project_id")
  title        String
  // iter = dernier index connu (fallback / legacy) ; iterationPath = clé stable
  // (System.IterationPath) qui survit au réordonnancement des itérations ADO.
  iter          Int
  iterationPath String? @map("iteration_path")
  color         String

  @@index([adoProjectId])
  @@map("milestones")
}

/// Flag posé sur une ligne (epic/feature) du Release planning, persisté par
/// projet ADO — partagé entre sessions et conservé après leur expiration.
model RowPin {
  id           String @id @default(uuid())
  adoProjectId String @map("ado_project_id")
  rowKey       String @map("row_key")
  iter          Int
  iterationPath String? @map("iteration_path")
  title         String
  color         String

  @@index([adoProjectId])
  @@map("row_pins")
}

model OperationsLog {
  id              String   @id @default(uuid())
  sessionId       String   @map("session_id")
  ticketId        String   @map("ticket_id")
  field           String
  oldValue        String?  @map("old_value")
  newValue        String?  @map("new_value")
  performedBy     String   @map("performed_by")
  performedAt     DateTime @default(now()) @map("performed_at")
  adoSyncStatus   String   @default("pending") @map("ado_sync_status")

  session   PlanningSession @relation(fields: [sessionId], references: [id])
  performer User            @relation(fields: [performedBy], references: [id])

  @@index([sessionId])
  @@index([ticketId])
  @@map("operations_log")
}

/// Capacité d'un membre pour une itération, persistée par projet ADO (pas par
/// session) — survit donc à l'expiration des sessions. `memberHash` = sha256 de
/// l'identifiant ADO du membre : aucune donnée personnelle (email/nom) en base ;
/// le mapping vers la personne se refait en session via la liste d'équipe ADO.
model Capacity {
  adoProjectId  String   @map("ado_project_id")
  iterationPath String   @map("iteration_path")
  memberHash    String   @map("member_hash")
  value         Float
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@id([adoProjectId, iterationPath, memberHash])
  @@map("capacities")
}

/// Poste/rôle d'un membre, propres à l'app (hors ADO), persistés par projet ADO.
/// `memberHash` = sha256 de l'identifiant ADO (aucune donnée personnelle en base) ;
/// remappé sur la personne en session via la liste d'équipe ADO.
model MemberMeta {
  adoProjectId String   @map("ado_project_id")
  memberHash   String   @map("member_hash")
  poste        String   @default("")
  role         String   @default("")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@id([adoProjectId, memberHash])
  @@map("member_meta")
}

model TicketsCache {
  id            String   @id
  sessionId     String   @map("session_id")
  title         String
  workItemType  String   @default("") @map("work_item_type")
  parentId      String?  @map("parent_id")
  state         String   @default("")
  tags          String[] @default([])
  assigneeId    String?  @map("assignee_id")
  areaPath      String   @map("area_path")
  iterationId   String   @map("iteration_id")
  epicId        String?  @map("epic_id")
  epicTitle     String?  @map("epic_title")
  startDate     DateTime @map("start_date")
  endDate       DateTime @map("end_date")
  targetDate    DateTime? @map("target_date")
  estimateHours Float    @default(0) @map("estimate_hours")
  storyPoints   Float    @default(0) @map("story_points")
  adoRev        Int      @map("ado_rev")
  syncStatus    String   @default("synced") @map("sync_status")
  updatedAt     DateTime @updatedAt @map("updated_at")

  session PlanningSession @relation(fields: [sessionId], references: [id])

  @@index([iterationId])
  @@map("tickets_cache")
}
