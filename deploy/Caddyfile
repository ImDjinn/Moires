# HTTPS auto (Let's Encrypt) pour le domaine. Front statique + proxy vers l'API.
# moires.byimad.net = alias du portail byimad, même app.
themoirai.net, moires.byimad.net {
	encode gzip zstd

	# En-têtes de sécurité. HSTS (Caddy sert déjà en HTTPS), anti-sniffing,
	# anti-clickjacking, et fuite de referer limitée. Pas de CSP : l'app utilise
	# massivement des styles inline (styles React) qu'une CSP stricte casserait.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Routes back-end (NestJS) + WebSocket Socket.io → conteneur `api`.
	# `handle` = blocs mutuellement exclusifs : évite que try_files (exécuté avant
	# reverse_proxy dans l'ordre auto de Caddy) réécrive les routes API vers index.html.
	# `/sessions` nu = POST de création de session (non couvert par /sessions/*).
	@api path /auth/* /sessions /sessions/* /ado/* /socket.io/*
	handle @api {
		reverse_proxy api:3000
	}

	# SPA : tout le reste sert les fichiers statiques, fallback index.html
	handle {
		root * /srv
		# Assets hashés (index-XXXX.js/css) : immuables, cache long. index.html et
		# le reste : no-cache → le navigateur revalide à chaque déploiement et ne
		# sert jamais un vieux bundle après une mise à jour.
		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"
		@notassets not path /assets/*
		header @notassets Cache-Control "no-cache"
		try_files {path} /index.html
		file_server
	}
}

# Portail byimad.net : landing statique + page Parthenon. Contenu monté depuis
# le repo byimad cloné à côté du repo moirai (voir docker-compose.prod.yml).
byimad.net {
	encode gzip zstd
	root * /srv/byimad
	file_server
}

www.byimad.net {
	redir https://byimad.net{uri} permanent
}

# Parthenon est une app desktop (Electron) : page de présentation + releases
# auto-hébergées (installeurs + manifestes latest.yml pour electron-updater).
parthenon.byimad.net {
	encode gzip zstd

	# Installeurs uploadés dans /opt/parthenon-releases sur le VPS (voir
	# docker-compose.prod.yml). Pas de cache sur les manifestes latest*.yml :
	# l'auto-updater doit toujours voir la dernière version.
	handle_path /releases/* {
		root * /srv/parthenon-releases
		@manifests path *.yml
		header @manifests Cache-Control "no-cache"
		file_server
	}

	handle {
		root * /srv/byimad/parthenon
		file_server
	}
}
